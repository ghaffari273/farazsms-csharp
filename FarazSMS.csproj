<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target so .NET Framework projects (4.6.1–4.8.1) get a directly
         compatible assembly, while .NET Core/5+/.NET Standard use netstandard2.0.
         net461 is the floor because System.Text.Json 6.x supports .NET Framework 4.6.1+. -->
    <TargetFrameworks>netstandard2.0;net461</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- NuGet package metadata -->
    <IsPackable>true</IsPackable>
    <PackageId>FarazSMS</PackageId>
    <Version>1.1.2</Version>
    <Authors>FarazSMS</Authors>
    <Company>FarazSMS</Company>
    <Description>Official .NET client for FarazSMS / IranPayamak (فراز اس ام اس · ایران پیامک) — https://farazsms.com. Send pattern/OTP, bulk SMS, reports, phonebook, and all 63 endpoints. Works on .NET Framework 4.6.1+ (incl. 4.8) and .NET Core/5+.</Description>
    <PackageProjectUrl>https://farazsms.com</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>farazsms;iranpayamak;sms;otp;iran</PackageTags>
    <RepositoryUrl>https://github.com/ghaffari273/farazsms-csharp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="6.0.10" />
  </ItemGroup>

  <!-- .NET Framework target: System.Net.Http is in-box; reference assemblies
       let the net461 target build on Linux/macOS CI runners. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net461'">
    <Reference Include="System.Net.Http" />
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

</Project>
